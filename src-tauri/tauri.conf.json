{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Emen Kanban",
  "version": "0.1.0",
  "identifier": "com.emen.kanban",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Emen Kanban",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "category": "Productivity",
    "shortDescription": "Personal kanban over Obsidian markdown",
    "longDescription": "Native macOS kanban app yang baca/tulis task sebagai .md file di vault Obsidian.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/superemem/emen-kanban/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNGQTU1NTc0MkFEOTc1MUIKUldRYmRka3FkRldsUDErMDNMS1BmWE91ckZMdWNsUzhVMkk4TkZhVWNZbEFCZEVTTjJVdnMyNWsK",
      "dialog": true
    }
  }
}
